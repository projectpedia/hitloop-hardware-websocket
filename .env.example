# GroupLoop environment configuration
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# Public domain for the client hub (HTTP/HTTPS)
CLIENT_HUB_DOMAIN=

# Public domain for the WebSocket server
SOCKET_DOMAIN=

# WebSocket URL used by browser apps
WS_DEFAULT_URL=

# CDN base URL for shared assets
CDN_BASE_URL=

# Default app to load on the landing page (leave empty for default)
DEFAULT_APP=
